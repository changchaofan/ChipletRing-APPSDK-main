<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="@dimen/dp_300"
    android:layout_height="wrap_content"
    android:background="@drawable/box_white_bg_radius"
    android:orientation="vertical"
    android:paddingStart="@dimen/dp_24"
    android:paddingEnd="@dimen/dp_24">

    <TextView
        android:id="@+id/view_dialog_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/dp_26"
        android:fontFamily="sans-serif-light"
        android:text="title"
        android:textColor="#ffffff"
        android:textFontWeight="400"
        android:textSize="@dimen/sp_16"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/view_dialog_msg"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/dp_8"
        android:fontFamily="sans-serif-light"
        android:text="msg"
        android:textColor="#ffffff"
        android:textFontWeight="400"
        android:textSize="@dimen/sp_14" />

    <LinearLayout

        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_26"
        android:layout_marginBottom="@dimen/dp_16">

        <TextView
            android:id="@+id/view_dialog_cancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/btn_bg1"
            android:fontFamily="sans-serif-light"
            android:gravity="center"
            android:paddingTop="@dimen/dp_7"
            android:paddingBottom="@dimen/dp_7"
            android:text="@string/cancel"
            android:textColor="#ffffff"
            android:textFontWeight="400"
            android:textSize="@dimen/sp_16" />

        <TextView
            android:id="@+id/view_dialog_commit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dp_12"
            android:layout_weight="1"
            android:background="@drawable/btn_bg1"
            android:fontFamily="sans-serif-light"
            android:gravity="center"
            android:paddingTop="@dimen/dp_7"
            android:paddingBottom="@dimen/dp_7"
            android:text="@string/dialog_commit"
            android:textColor="@color/white"
            android:textFontWeight="400"
            android:textSize="@dimen/sp_16" />
    </LinearLayout>
</LinearLayout>